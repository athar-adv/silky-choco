---
import LayoutFriendo6 from "@/layouts/LayoutFriendo6.astro";
---

<LayoutFriendo6 title="Menu - FRIENDo6" activeTab="menu">
  <section>
    <h2>Menu Kita</h2>
    <p style="text-align: center; color: #666; margin-bottom: 2rem;">
      Pilih yang anda suka :D
    </p>

    <div class="grid">
      <div class="card">
        <div class="card-image">🍫</div>
        <h3>Pudding Silky Choco</h3>
        
        <p>
          <strong>Penyuka Pudding</strong> - Lebih banyak pudding
          <h2 style="margin: 0.5rem 0; color: #6b4423;">10.000Rp.-</h2>
        </p>
        <p>
          <strong>Penyuka Biskuit</strong> - Lebih banyak biskuit
          <h2 style="margin: 0.5rem 0; color: #6b4423;">8.000Rp.-</h2>
        </p>

        <p style="margin-top: 1rem; color: #999; font-size: 0.9rem;">Sedia dalam berbagai ukuran</p>
      </div>
    </div>
  </section>
</LayoutFriendo6>

<style>
  p {
    margin: 0;
  }
</style>
