<button class="hamburger-open" id="hamburger-open">&#9776;</button>

<nav id="navbar" class="no-transition">
  <button class="hamburger-close" id="hamburger-close">✕</button>
  <div class="logo">
    <img src="/fo6.svg" />
    <span class="tagline">Untuk semua kebutuhan sepedamu</span>
  </div>

  <div class="links">
    <a href="/">Beranda</a>
    <a href="/marketplace">Marketplace</a>
    <a href="/post">Post</a>
    <a href="/aboutus">Hubungi Kita</a>
  </div>
</nav>

<div class="overlay" id="overlay"></div>

<script>
  const hamburgerOpen = document.getElementById('hamburger-open')!;
  const hamburgerClose = document.getElementById('hamburger-close')!;
  const navbar = document.getElementById('navbar')!;
  const overlay = document.getElementById('overlay')!;

  // const isOpen = localStorage.getItem('nav-open') === 'true';
  // if (isOpen) {
  //   navbar.classList.add('open');
  //   overlay.classList.add('open');
  // }

  requestAnimationFrame(() => {
    navbar.classList.remove('no-transition');
  });

  hamburgerOpen.addEventListener('click', () => {
    navbar.classList.add('open');
    overlay.classList.add('open');
    //localStorage.setItem('nav-open', 'true');
  });

  hamburgerClose.addEventListener('click', () => {
    navbar.classList.remove('open');
    overlay.classList.remove('open');
    //localStorage.setItem('nav-open', 'false');
  });

  overlay.addEventListener('click', () => {
    navbar.classList.remove('open');
    overlay.classList.remove('open');
    //localStorage.setItem('nav-open', 'false');
  });
</script>

<style>
  :root {
    --nav-width: 260px;
  }

  nav {
    width: var(--nav-width);
    height: 100vh;
    padding: 1.5rem 1.25rem;
    display: flex;
    flex-direction: column;
    border-right: 0.5px solid #e0e0e0;
  }

  .logo {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-bottom: 2rem;
  }

  .tagline {
    font-size: 12px;
    color: #888;
    text-align: center;
  }

  .links {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .links a {
    font-size: 14px;
    text-decoration: none;
    color: inherit;
    padding: 8px 10px;
    border-radius: 8px;
  }

  .links a:hover { background: #f5f5f5; }
  .links a.active { background: #f5f5f5; color: #000; }

  .hamburger-open,
  .hamburger-close {
    display: none;
  }

  .overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.3);
    z-index: 99;
  }

  @media(max-width: 768px) {
    nav.no-transition {
      transition: none !important;
    }
    /* the open button — fixed to viewport, low z-index so nav slides over it */
    .hamburger-open {
      display: block;
      position: fixed;
      top: 1rem;
      left: 0;
      z-index: 90; /* below nav's z-index of 100 */
      background: white;
      border: 0.5px solid #e0e0e0;
      border-left: none;
      border-radius: 0 8px 8px 0;
      padding: 4px 10px;
      font-size: 18px;
      cursor: pointer;
    }

    /* the close button — sits inside the nav */
    .hamburger-close {
      display: block;
      align-self: flex-end;
      background: none;
      border: none;
      font-size: 18px;
      cursor: pointer;
      padding: 4px 8px;
      margin-bottom: 1rem;
    }

    nav {
      position: fixed;
      left: calc(-1 * (var(--nav-width) + 40px));
      top: 0;
      width: var(--nav-width);
      z-index: 100;
      background: white;
      overflow: hidden;
      transition: left 0.25s ease;
    }

    nav.open {
      left: 0;
    }

    .overlay.open {
      display: block;
    }
  }
</style>