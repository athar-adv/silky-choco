---
const { columns: _columns, max_width, min_col_width = "200px" } = Astro.props
const columns = _columns ? Number(_columns) : null
const id = `list-${Math.random().toString(36).slice(2, 7)}`
---

<div
  id={id}
  class="list"
  class:list={[{ 'list--grid': columns }]}
  style={max_width ? `max-width: ${max_width}` : ''}
  data-columns={columns}
  data-min-col-width={min_col_width}
>
  <slot />
</div>

<script>
  function updateColumns(el: HTMLElement) {
    const maxCols = Number(el.dataset.columns)
    const minColWidth = parseInt(el.dataset.minColWidth ?? "200")
    const width = el.offsetWidth
    const fitCols = Math.floor(width / minColWidth)
    const cols = Math.min(maxCols, Math.max(1, fitCols))
    el.style.gridTemplateColumns = `repeat(${cols}, minmax(0, 1fr))`
  }
  
  document.querySelectorAll<HTMLElement>('.list--grid, .list').forEach(el => {
    updateColumns(el)
    new ResizeObserver(() => updateColumns(el)).observe(el)

    Array.from(el.children).forEach((child, i) => {
      (child as HTMLElement).style.animationDelay = `${i * 60}ms`
    })
  })
</script>

<style>
  .list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    box-sizing: border-box;
    padding-left: 0.2rem;
    padding-right: 0.2rem;
    width: 100%;
  }

  .list--grid {
    display: grid;
    gap: 0.5rem;
  }

  .list > :global(*) {
    animation: fade-up 0.4s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  
  @keyframes fade-up {
    from {
      opacity: 0;
      translate: 0 12px;
    }
    to {
      opacity: 1;
      translate: 0 0;
    }
  }
</style>