---
const { columns: _columns, max_width } = Astro.props
const columns = _columns ? String(_columns) : null
---
<div 
  class="list"
  class:list={[{ 'list--grid': columns }]}
  style={[
    columns ? `--columns: ${columns}` : '',
    max_width ? `--max-width: ${max_width}` : ''
  ].join('; ')}
>
  <slot />
</div>

<style>
  .list
  {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    box-sizing: border-box;
    padding-left: 0.2rem;
    padding-right: 0.2rem;
    max-width: var(--max-width, none);
  }

  .list--grid
  {
    display: grid;
    grid-template-columns: repeat(var(--columns, 16), 1fr);
    gap: 0.5rem;
  }
</style>